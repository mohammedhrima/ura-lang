// game/world.ura - arrays in every form, loops, and match.
// Imported from a subdirectory, so the path resolves against THIS file.

use "../vec"

struct Room:
    floor i32
    kind  i32
    pos   Vec2

    pub fn create(f i32, k i32) Room:
        r Room
        r.floor = f
        r.kind  = k
        r.pos   = Vec2::create(f, k)
        return r

    fn label() chars:
        name chars = "?"
        match self.kind:
            case 0:
                name = "empty"
            case 1, 2:
                name = "monster"
            case 3:
                name = "treasure"
            default:
                name = "sealed"
        return name

    fn show() void:
        output("  floor ", self.floor, " ", self.label(), "\n")

struct World:
    grid  i32[][]
    rooms Room[]
    depth i32

    pub fn create(depth i32, width i32) World:
        w World
        w.grid  = new i32[depth][width]
        w.rooms = new Room[depth]
        w.depth = depth
        i i32 = 0
        while i < depth:
            w.rooms[i] = Room::create(i, i % 4)
            j i32 = 0
            while j < width:
                w.grid[i][j] = (i + 1) * (j + 1)
                j += 1
            i += 1
        return w

    fn width() u64:
        return self.grid[0].len

    fn cell(r i32, c i32) i32:
        return self.grid[r][c]?

    fn show_grid() void:
        for row in self.grid:
            output("  ")
            for v in row:
                output(v, " ")
            output("\n")

    fn double_floors() void:
        for ref r in self.rooms:
            r.floor = r.floor * 2

    fn show_rooms() void:
        for r in self.rooms:
            r.show()

    fn show_slice(r i32, lo i32, hi i32) void:
        part i32[] = self.grid[r][lo..hi]
        output("  slice [", lo, "..", hi, "] ")
        for v in part:
            output(v, " ")
        output("len ", part.len, "\n")

    fn total() i32:
        sum i32 = 0
        for row in self.grid:
            for v in row:
                sum += v
        return sum

    fn first_treasure() i64:
        i u64 = 0
        loop:
            if i >= self.rooms.len:
                break
            if self.rooms[i].kind != 3:
                i += 1
                continue
            return i as i64
        return 0 - 1

    // World owns two heap arrays, so a copy must take its own
    operator =(other World) void:
        clean self.grid
        clean self.rooms
        self.depth = other.depth
        self.grid  = new i32[other.depth][other.width()]
        self.rooms = new Room[other.depth]
        i i32 = 0
        while i < other.depth:
            self.rooms[i] = other.rooms[i]
            j u64 = 0
            while j < other.width():
                self.grid[i][j] = other.grid[i][j]
                j += 1
            i += 1

    operator drop:
        output("  drop world of depth ", self.depth, "\n")
        clean self.grid
        clean self.rooms