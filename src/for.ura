main():
    output("up:   ")
    for i in 0..5:
        output(i, " ")
    output("\ndown: ")
    for i in 5..0:
        output(i, " ")
    output("\nsum 0..10 (skip 5): ")
    n int = 10
    total int = 0
    for i in 0..n:
        if i == 5:
            continue
        total = total + i
    output(total, "\n")
