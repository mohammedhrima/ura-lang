// dungeon/floor10b.ura
main():
    board array[[int]] = stack[[int]](4, 3)

    r int = 0
    while r < 4:
        c int = 0
        while c < 3:
            board[r][c] = r * 3 + c
            c = c + 1
        r = r + 1

    r = 0
    while r < 4:
        c int = 0
        while c < 3:
            output(board[r][c], " ")
            c = c + 1
        output("\n")
        r = r + 1
