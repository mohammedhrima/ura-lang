// dungeon/floor07a.ura
struct Player:
    name  chars
    hp    int
    mp    int

struct Enemy:
    name  chars
    hp    int
    atk   int

fn fight(p Player, e Enemy) void:
    output(p.name, " (", p.hp, " HP) faces ", e.name, " (", e.hp, " HP)\n")
    if p.hp > e.hp:
        output(p.name, " wins!\n")
    else:
        output(e.name, " wins!\n")

main():
    hero Player
    hero.name = "Aldric"
    hero.hp   = 100
    hero.mp   = 50

    orc Enemy
    orc.name = "Orc Grunt"
    orc.hp   = 60
    orc.atk  = 14

    fight(hero, orc)
