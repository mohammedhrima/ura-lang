// dungeon/floor19 — array literals
use "@/header"

main():
    enemies array[chars] = ["Orc", "Spider", "Dragon"]
    loot    array[int]   = [15, 30, 100]

    output("Enemies: ", enemies[0], ", ", enemies[1], ", ", enemies[2], "\n")
    output("Loot:    ", loot[0], ", ", loot[1], ", ", loot[2], " gold\n")

    roll int = 4
    output("Roll ", roll, ": ", enemies[roll % 3], "\n")

    hits array[int] = [12, 8, 15, 20]
    total int = 0
    i int = 0
    while i < 4:
        total += hits[i]
        i += 1
    output("Total damage: ", total, "\n")

    hp_stages array[int] = [100, 100 - 12, 100 - 12 - 8, 100 - 12 - 8 - 15]
    output("HP: ", hp_stages[0], " -> ", hp_stages[1], " -> ", hp_stages[2], " -> ", hp_stages[3], "\n")

    spells array[chars] = ["Fireball", "Ice Shard", "Lightning"]
    output("Spell book: ", spells[0], ", ", spells[1], ", ", spells[2], "\n")
