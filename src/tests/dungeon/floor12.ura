// dungeon/floor12.ura
main():
    score     int   = 847
    max_score int   = 1000
    pct       float = score as float / max_score as float * 100.0
    output("Score: ", score, "/", max_score, "  Rating: ", pct, "%\n")

    grade char = 'A'
    code  int  = grade as int
    back  char = (code + 1) as char
    output("Grade: ", grade, " → ", code, " → ", back, "\n")

    diff int = 'd' as int - 'a' as int
    output("'d' - 'a' = ", diff, "\n")
