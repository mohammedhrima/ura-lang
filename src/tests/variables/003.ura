// variables/003.ura - all primitive types in one place

main():
    name   chars = "Aldric"
    hp     int   = 100
    xp     long  = 999999 as long
    level  short = 12 as short
    grade  char  = 'S'
    alive  bool  = True
    ratio  float = 0.85

    output("name:  ", name,  "\n")
    output("hp:    ", hp,    "\n")
    output("xp:    ", xp,    "\n")
    output("level: ", level, "\n")
    output("grade: ", grade, "\n")
    output("alive: ", alive, "\n")
    output("ratio: ", ratio, "\n")
