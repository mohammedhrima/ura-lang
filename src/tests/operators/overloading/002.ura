// operators/overloading/002.ura

struct Score:
    val int

    operator = (n int) void:
        self.val = n

    operator == (s Score ref) bool:
        return self.val == s.val

    operator != (s Score ref) bool:
        return self.val != s.val

    operator < (s Score ref) bool:
        return self.val < s.val

    operator > (s Score ref) bool:
        return self.val > s.val

    operator <= (s Score ref) bool:
        return self.val <= s.val

    operator >= (s Score ref) bool:
        return self.val >= s.val

main():
    a Score
    a.val = 50

    b Score
    b.val = 80

    output("a == b: ", a == b, "\n")
    output("a != b: ", a != b, "\n")
    output("a <  b: ", a < b,  "\n")
    output("a >  b: ", a > b,  "\n")
    output("a <= b: ", a <= b, "\n")
    output("a >= b: ", a >= b, "\n")
