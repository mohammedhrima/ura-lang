// globals/003.ura - global struct: kill counter with init/clean

use "@/header"

struct KillCounter:
    value int
    label chars

    pub fn new() KillCounter:
        k KillCounter
        k.value = 0
        k.label = strdup("kills")
        return k

    fn tick() void:
        self.value += 1

    fn print() void:
        output(self.label, ": ", self.value, "\n")

    operator delete() void:
        free(self.label)

counter KillCounter

main():
    counter.label = strdup("kills")
    counter.tick()
    counter.tick()
    counter.tick()
    counter.print()
