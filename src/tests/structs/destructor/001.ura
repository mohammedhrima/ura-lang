// structs/destructor/001 — operator delete auto-called at scope exit
use "@/header"

struct Tracker:
    id int

    pub fn new(id int) Tracker:
        t Tracker
        t.id = id
        output("create ", id, "\n")
        return t

    operator delete() void:
        output("delete ", self.id, "\n")

main():
    a Tracker = Tracker::new(1)
    b Tracker = Tracker::new(2)
    output("using ", a.id, " and ", b.id, "\n")
