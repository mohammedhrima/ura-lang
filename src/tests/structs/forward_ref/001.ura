// structs/forward_ref/001 — methods calling each other out of order

struct Calc:
    result int

    pub fn new(v int) Calc:
        c Calc
        c.set(v)
        return c

    fn double() void:
        self.result = self.get() * 2

    fn set(v int) void:
        self.result = v

    fn get() int:
        return self.result

main():
    c Calc = Calc::new(21)
    c.double()
    output(c.get(), "\n")
