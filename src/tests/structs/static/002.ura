// structs/static/002 — pub fn with different return types
use "@/header"

struct Counter:
    value int

    pub fn new() Counter:
        c Counter
        c.value = 0
        return c

    pub fn from(v int) Counter:
        c Counter
        c.value = v
        return c

    fn inc() void:
        self.value += 1

    fn get() int:
        return self.value

main():
    a Counter = Counter::new()
    output(a.get(), "\n")
    b Counter = Counter::from(42)
    output(b.get(), "\n")
    b.inc()
    b.inc()
    output(b.get(), "\n")
