{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ura",
  "scopeName": "source.ura",
  "patterns": [
    { "include": "#comments" },
    { "include": "#imports" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#numbers" },
    { "include": "#special_methods" },
    { "include": "#keywords" },
    { "include": "#declarations" },
    { "include": "#library" },
    { "include": "#types" },
    { "include": "#struct_definitions" },
    { "include": "#custom_types" },
    { "include": "#booleans" },
    { "include": "#builtins" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ura",
          "match": "//.*$"
        },
        {
          "name": "comment.block.ura",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },

    "imports": {
      "patterns": [
        {
          "comment": "use \"@/module\" or use \"./module\" — highlight path distinctly",
          "name": "meta.import.ura",
          "match": "\\b(use)\\s+(\"[^\"]+\")",
          "captures": {
            "1": { "name": "keyword.library.ura" },
            "2": { "name": "string.quoted.double.import.ura" }
          }
        }
      ]
    },

    "strings": {
      "name": "string.quoted.double.ura",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "include": "#printf-format-specifiers" },
        {
          "name": "constant.character.escape.ura",
          "match": "\\\\."
        }
      ]
    },

    "printf-format-specifiers": {
      "patterns": [
        {
          "name": "constant.character.format.placeholder.ura",
          "match": "%([-+0 #])?([0-9]+|\\*)?(\\.([0-9]+|\\*))?([hlLzjt]|hh|ll)?[diuoxXfFeEgGaAcspn%]"
        }
      ]
    },

    "characters": {
      "patterns": [
        {
          "name": "string.quoted.single.ura",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.ura",
              "match": "\\\\."
            }
          ]
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.ura",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.ura",
          "match": "\\b\\d+\\b"
        }
      ]
    },

    "special_methods": {
      "patterns": [
        {
          "comment": "fn init / fn clean — constructor/destructor methods",
          "match": "\\b(fn)\\s+(init|clean)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.ura" },
            "2": { "name": "keyword.other.special-method.ura" }
          }
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ura",
          "match": "\\b(if|elif|else|while|for|return|break|continue|and|or|is|not|self)\\b"
        }
      ]
    },

    "declarations": {
      "patterns": [
        {
          "name": "keyword.declaration.ura",
          "match": "\\b(struct|fn|as)\\b"
        }
      ]
    },

    "library": {
      "patterns": [
        {
          "name": "keyword.library.ura",
          "match": "\\b(use|proto)\\b"
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "storage.type.ura",
          "match": "\\b(int|float|double|char|void|long|short|unsigned|signed|bool|chars|pointer|ref|array)\\b"
        }
      ]
    },

    "struct_definitions": {
      "patterns": [
        {
          "name": "entity.name.type.struct.ura",
          "match": "(?<=\\bstruct\\s{1,64})([A-Z][a-zA-Z0-9_]*)(?=\\s*:)"
        }
      ]
    },

    "custom_types": {
      "patterns": [
        {
          "comment": "Variable declaration with custom type: 'varname TypeName'",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "variable.other.ura" },
            "2": { "name": "entity.name.type.ura" }
          }
        }
      ]
    },

    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.ura",
          "match": "\\b(True|False|NULL)\\b"
        }
      ]
    },

    "builtins": {
      "patterns": [
        {
          "comment": "stack[Type](n) / heap[Type](n) / array[Type] — any identifier in brackets",
          "name": "meta.stack.ura",
          "match": "(stack|heap|array)(\\[[\\w]+\\])",
          "captures": {
            "1": { "name": "support.function.builtin.ura" },
            "2": { "name": "storage.type.ura" }
          }
        },
        {
          "name": "support.function.builtin.ura",
          "match": "\\b(stack|heap|output|typeof|sizeof)\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.ura",
          "match": "==|!=|<=|>=|<<|>>|\\+=|-=|\\*=|/=|%=|&&|\\|\\||[!~^]|[&|]|[+\\-*/<>%=]"
        }
      ]
    },

    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.ura",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },

    "variables": {
      "patterns": [
        {
          "name": "variable.other.ura",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b(?!\\s*\\()"
        }
      ]
    }
  }
}
