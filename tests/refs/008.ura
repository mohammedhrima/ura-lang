// refs/008 — a ref reads correctly through every operator + as a by-value arg

fn twice(n int) int:
    return n * 2

main():
    x int = 12
    ref r int = ref x
    output(r + 3, "\n")
    output(r - 5, "\n")
    output(r * 2, "\n")
    output(r > 10, "\n")
    output(r == 12, "\n")
    output(r & 10, "\n")
    output(r << 1, "\n")
    output(-r, "\n")
    output(~r, "\n")
    output(twice(r), "\n")
    return 0