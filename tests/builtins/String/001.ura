// builtins/String/001.ura - string struct
use "@/header"

fn strjoin(left chars, right chars) chars:
    len1 int = 0
    len2 int = 0
    if left != null:  len1 = strlen(left)
    if right != null: len2 = strlen(right)
    str chars = calloc((len1 + len2 + 1) as long, 1)
    i int = 0
    while i < len1:
        str[i] = left[i]
        i += 1
    j int = 0
    while j < len2:
        str[i + j] = right[j]
        j += 1
    return str

struct String:
    value chars
    count int
    size  int

    fn init() void:
        self.size  = 10
        self.value = calloc(10 as long, 1 as long)

    fn clean() void:
        free(self.value)

    fn assign(str chars) void:
        if str == null: str = ""
        len int = strlen(str)
        if self.size < len:
            while self.size < len:
                self.size *= 2
            self.value = realloc(self.value, self.size)
        strcpy(self.value, str)
        bzero(self.value + len, (self.size - len) as long)
        self.count = len

    fn join(str chars) void:
        if str == null: return
        res chars = strjoin(self.value, str)
        self.assign(res)
        free(res)

    operator = (str chars) void:
        self.assign(str)

    operator = (v String ref) void:
        self.assign(v.value)

    operator + (v String ref) String:
        res String = strjoin(self.value, v.value)
        return res


main():
    s0 String = "12345"
    s1 String = "6789"
    s2 String = s0 + s1
    output("value: ", s2.value, "\n")
