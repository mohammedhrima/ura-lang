// builtins/output/001.ura
use "@/header"

struct File:
    path chars
    handle pointer

    fn init() void:
        output("call File.init\n")

    fn setPath(path chars) void:
        self.path = strdup(path)
        self.handle = fopen(path, "w")

    fn write(msg chars) void:
        output("File.write -> ", msg, "\n")

    fn clean() void:
        output("call File.clean\n")
        fclose(self.handle)
        free(self.path)


struct Logger:
    file File
    prefix chars

    fn init() void:
        output("call Logger.init\n")
        self.file.setPath("app.log")
        self.prefix = strdup("[APP] ")

    fn log(msg chars) void:
        output(self.prefix, msg, "\n")
        self.file.write(msg)

    fn clean() void:
        output("call Logger.clean\n")
        free(self.prefix)


struct App:
    logger Logger
    name chars

    fn init() void:
        output("call App.init\n")
        self.logger.init()
        self.name = strdup("UraApp")

    fn run() void:
        self.logger.log("application started")
        self.logger.log(self.name)

    fn clean() void:
        output("call App.clean\n")
        free(self.name)


main():
    app App
    app.run()