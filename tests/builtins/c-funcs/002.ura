// builtins/c-funcs/002.ura - custom putchar via write syscall: print dungeon tiles

proto fn write(fd int, ptr chars, len int) int

fn putchar(c char) int:
    buf chars = stack[char](2)
    buf[0] = c
    write(1, buf, 1)
    return 0

main():
    putchar('D')
    putchar('U')
    putchar('N')
    putchar('G')
    putchar('E')
    putchar('O')
    putchar('N')
    putchar('\n')
    return 0
