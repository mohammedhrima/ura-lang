// dungeon/floor08.ura
use "@/header"

struct Hero:
    name  chars
    title chars
    hp    int

    fn init() void:
        self.name  = heap[char](32)
        self.title = heap[char](32)
        self.hp    = 100

    fn setup(name chars, title chars) void:
        strcpy(self.name,  name)
        strcpy(self.title, title)

    fn announce() void:
        output(self.title, " ", self.name, " — HP: ", self.hp, "\n")

    fn heal(amount int) void:
        self.hp = self.hp + amount

    fn clean() void:
        free(self.name)
        free(self.title)

main():
    hero Hero
    hero.setup("Aldric", "The Bold")
    hero.announce()
    hero.heal(20)
    hero.announce()
