// dungeon/floor13b.ura
use "@/header"

struct Label:
    value chars
    len   int

    fn init() void:
        self.value = heap[char](64)
        self.len   = 0

    fn clean() void:
        free(self.value)

    fn set(s chars) void:
        strcpy(self.value, s)
        self.len = strlen(s) as int

    operator = (s chars) void:
        self.set(s)

    operator = (v Label ref) void:
        self.set(v.value)

    operator + (v Label ref) Label:
        res Label
        strcpy(res.value, self.value)
        strcat(res.value, v.value)
        res.len = self.len + v.len
        return res

    fn print() void:
        output(self.value, " (", self.len, " chars)\n")

main():
    title Label
    title = "Shadow"

    name Label
    name = "Aldric"

    full Label = title + name
    full.print()
