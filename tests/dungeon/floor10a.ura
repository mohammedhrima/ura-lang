// dungeon/floor10a.ura
use "@/header"

main():
    map chars = heap[char](51)
    i   int   = 0
    while i < 50:
        map[i] = '.'
        i = i + 1
    map[25] = '@'
    map[50] = 0 as char
    output(map, "\n")
    free(map)

    buf chars = stack[char](16)
    buf[0] = 'H'
    buf[1] = 'P'
    buf[2] = 0 as char
    output(buf, "\n")
