// dungeon/floor13c.ura
use "@/header"

struct Label:
    value chars
    len   int

    fn init() void:
        self.value = heap[char](64)
        self.len   = 0

    fn clean() void:
        free(self.value)

    fn set(s chars) void:
        strcpy(self.value, s)
        self.len = strlen(s) as int

    operator = (s chars) void:
        self.set(s)

    operator = (v Label ref) void:
        self.set(v.value)

    fn print() void:
        output(self.value, "\n")

fn hero_rename(hero Label, suffix chars) void:
    strcat(hero.value, suffix)
    output("inside: ", hero.value, "\n")

main():
    hero Label
    hero = "Aldric"
    hero_rename(hero, " the Brave")
    output("after:  ", hero.value, "\n")
