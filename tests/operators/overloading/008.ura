// operators/overloading/008.ura

struct Vec2:
    x int
    y int

    operator = (v Vec2 ref) void:
        self.x = v.x
        self.y = v.y

    operator * (v Vec2 ref) int:
        return self.x * v.x + self.y * v.y

main():
    a Vec2
    a.x = 3
    a.y = 4

    b Vec2
    b.x = 2
    b.y = 5

    dot int = a * b
    output("dot product: ", dot, "\n")

    c Vec2
    c.x = 1
    c.y = 0

    d Vec2
    d.x = 0
    d.y = 1

    perp int = c * d
    output("perpendicular: ", perp, "\n")
