// operators/overloading/001.ura

struct Vec2:
    x int
    y int

    operator = (v Vec2 ref) void:
        self.x = v.x
        self.y = v.y

    operator + (v Vec2 ref) Vec2:
        res Vec2
        res.x = self.x + v.x
        res.y = self.y + v.y
        return res

    operator - (v Vec2 ref) Vec2:
        res Vec2
        res.x = self.x - v.x
        res.y = self.y - v.y
        return res

    operator * (n int) Vec2:
        res Vec2
        res.x = self.x * n
        res.y = self.y * n
        return res

    operator / (n int) Vec2:
        res Vec2
        res.x = self.x / n
        res.y = self.y / n
        return res

main():
    a Vec2
    a.x = 3
    a.y = 3

    b Vec2
    b.x = 2
    b.y = 4

    add Vec2 = a + b
    output("add: (", add.x, ", ", add.y, ")\n")

    sub Vec2 = a - b
    output("sub: (", sub.x, ", ", sub.y, ")\n")

    mul Vec2 = a * 2
    output("mul: (", mul.x, ", ", mul.y, ")\n")

    div Vec2 = b / 2
    output("div: (", div.x, ", ", div.y, ")\n")
