// operators/overloading/009.ura
use "@/header"

fn strjoin(left chars, right chars) chars:
    len int = 0
    len1 int = 0
    len2 int = 0
    if left != null: len1 += strlen(left)
    if right != null: len2 += strlen(right)
    str chars = calloc((len1 + len2 + 1) as long, 1)
    i int = 0
    while i < len1:
        str[i] = left[i]
        i += 1
    j int = 0
    while j < len2:
        str[i + j] = right[j]
        j += 1
    return str

struct String2:
    value chars
    count int
    size int
    
    pub fn new() String2:
        s String2
        s.size  = 10
        s.value = calloc(10 as long, 1 as long)
        return s

    operator delete() void:
        free(self.value)

    fn assign (str chars) void:
        if str == null:
            self.assign("")
            return
        len int = strlen(str)
        if self.size < len:
            while self.size < len:
                self.size *= 2
            self.value = realloc(self.value, self.size)

        bzero(self.value, self.size as long)
        strcpy(self.value, str)
        self.count = len

    fn join(str chars) void:
        if str == null: return
        res chars = strjoin(self.value, str)
        self.assign(res)


    operator = (str chars) void:
        self.assign(str)

    operator = (v String2 ref) void:
        self.assign(v.value)

fn add (v String2 ref, w String2 ref) String2:
    output("v    -> ", v.value, "\n")
    output("self -> ", w.value, "\n")
    res String2 = String2::new()
    res = w
    return res
    
    

main():
    s0 String2 = String2::new()
    s0 = "12345"
    s1 String2 = String2::new()
    s1 = "6789"
    s2 String2 = String2::new()
    s2 = add(s0, s1)
    output("value: ", s2.value, "\n")
