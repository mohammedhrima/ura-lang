// structs/methods/st01.ura
use "@/header"

struct Name:
    value chars
    fn init() void:
        output("call Name.init\n")

    fn setValue(value chars) void:
        self.value = strdup(value)

    fn clean() void:
        output("call Name.clean\n")
        free(self.value)

struct User:
    age int
    name Name
    fn init() void:
        output("call User.init\n")
        self.age = 10
        self.name.setValue("user")
    fn clean() void:
        output("call User.clean\n")

main():
    user User
    output("hello ", user.name.value, " has ", user.age, "\n")
