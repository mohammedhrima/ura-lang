// structs/no-methods/st02.ura
use "@/header"

struct Model:
    name chars
    year int

struct Company:
    name chars

struct Car:
    model Model
    company Company

struct User:
    name chars
    age int
    car Car

main():
    user User
    user.name = "hello"
    user.age = 123
    user.car.model.name = "car"
    printf("%s\n", user.car.model.name)