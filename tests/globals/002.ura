// globals/002.ura - initialized globals: floor, lives, max_floor

floor     int  = 1
lives     int  = 3
max_floor int  = 10
hardcore  bool = True

main():
    output("Floor:     ", floor,     "\n")
    output("Lives:     ", lives,     "\n")
    output("Max floor: ", max_floor, "\n")
    output("Hardcore:  ", hardcore,  "\n")
