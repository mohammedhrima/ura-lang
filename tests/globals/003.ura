// globals/003.ura - global struct: kill counter with init/clean

use "@/header"

struct KillCounter:
    value int
    label chars

    fn init() void:
        self.value = 0
        self.label = strdup("kills")

    fn tick() void:
        self.value += 1

    fn print() void:
        output(self.label, ": ", self.value, "\n")

    fn clean() void:
        free(self.label)

counter KillCounter

main():
    counter.tick()
    counter.tick()
    counter.tick()
    counter.print()
