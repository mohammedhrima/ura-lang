// memory/004 — null pointer handling

use "@/header"

fn find_weapon(chest int) chars:
    if chest == 1: return "Iron Sword"
    if chest == 2: return "Magic Staff"
    return null   // chest is empty

main():
    loot chars = find_weapon(1)
    if loot != null:
        output("Found: ", loot, "\n")
    else:
        output("Chest is empty\n")

    loot = find_weapon(99)
    if loot != null:
        output("Found: ", loot, "\n")
    else:
        output("Chest is empty\n")