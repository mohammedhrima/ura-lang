// loops/004 — for loop range form with auto-direction
use "@/header"

main():
    for i from 0 to 5:
        output(i, " ")
    output("\n")

    for i from 5 to 0:
        output(i, " ")
    output("\n")

    for i from 0 to 20 step 5:
        output(i, " ")
    output("\n")

    for i from 20 to 0 step 5:
        output(i, " ")
    output("\n")

    for i from 0 to 100:
        if i > 3: break
        output(i, " ")
    output("\n")

    for i from 0 to 6:
        if i % 2 != 0: continue
        output(i, " ")
    output("\n")
