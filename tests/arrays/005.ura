// arrays/005 — array literal with expressions
use "@/header"

fn double(n int) int:
    return n * 2

main():
    x int = 5
    v array[int] = [x, x + 1, x * 2, double(x)]
    output(v[0], " ", v[1], " ", v[2], " ", v[3], "\n")

    dmg array[int] = [10 + 5, 20 - 3, 8 * 2]
    output(dmg[0], " ", dmg[1], " ", dmg[2], "\n")
