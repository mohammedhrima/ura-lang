proto fn printf(fmt chars, ...) int

main():
    a int = 60
    b int = 13

    // AND: 60 & 13 = 12
    r int = a & b
    printf("60 & 13 = %d (expected 12)\n", r)

    // OR: 60 | 13 = 61
    r = a | b
    printf("60 | 13 = %d (expected 61)\n", r)

    // XOR: 60 ^ 13 = 49
    r = a ^ b
    printf("60 ^ 13 = %d (expected 49)\n", r)

    // NOT: ~60 = -61
    r = ~a
    printf("~60 = %d (expected -61)\n", r)

    // LEFT SHIFT: 1 << 3 = 8
    r = 1 << 3
    printf("1 << 3 = %d (expected 8)\n", r)

    // RIGHT SHIFT: 60 >> 2 = 15
    r = 60 >> 2
    printf("60 >> 2 = %d (expected 15)\n", r)

    // COMBINED: (a & b) | (1 << 4) = 28
    r = (a & b) | (1 << 4)
    printf("(60 & 13) | (1 << 4) = %d (expected 28)\n", r)

    return 0