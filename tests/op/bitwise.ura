// op/bitwise.ura

main():
    a int = 60
    b int = 13

    // AND: 60 & 13 = 12
    r int = a & b
    output("60 & 13 = ", r, " (expected 12)\n")

    // OR: 60 | 13 = 61
    r = a | b
    output("60 | 13 = ", r, " (expected 61)\n")

    // XOR: 60 ^ 13 = 49
    r = a ^ b
    output("60 ^ 13 = ", r, " (expected 49)\n")

    // NOT: ~60 = -61
    r = ~a
    output("~60 = ", r, " (expected -61)\n")

    // LEFT SHIFT: 1 << 3 = 8
    r = 1 << 3
    output("1 << 3 = ", r, " (expected 8)\n")

    // RIGHT SHIFT: 60 >> 2 = 15
    r = 60 >> 2
    output("60 >> 2 = ", r, " (expected 15)\n")

    // COMBINED: (a & b) | (1 << 4) = 28
    r = (a & b) | (1 << 4)
    output("(60 & 13) | (1 << 4) = ", r, " (expected 28)\n")

    return 0
