// op/logical.ura
use "@/io"

fn t() bool:
    return True

fn f() bool:
    return False

fn print_bool(label chars, val bool) void:
    if val:
        printf("%sTrue\n", label)
    else:
        printf("%sFalse\n", label)

main():
    a bool = True
    b bool = False

    // AND
    print_bool("and var&&var (F): ", a && b)
    print_bool("and var&&val (T): ", a && True)
    print_bool("and var&&fn  (T): ", a && t())
    print_bool("and val&&var (F): ", False && a)
    print_bool("and val&&val (T): ", True && True)
    print_bool("and val&&fn  (F): ", True && f())
    print_bool("and fn&&var  (T): ", t() && a)
    print_bool("and fn&&val  (F): ", f() && True)
    print_bool("and fn&&fn   (F): ", t() && f())
    print_bool("and keyword  (F): ", a and b)
    print_bool("and False&&fn(F): ", False && t())

    // OR
    print_bool("or  var||var (T): ", a || b)
    print_bool("or  var||val (T): ", b || True)
    print_bool("or  var||fn  (T): ", b || t())
    print_bool("or  val||var (T): ", False || a)
    print_bool("or  val||val (F): ", False || False)
    print_bool("or  val||fn  (F): ", False || f())
    print_bool("or  fn||var  (T): ", f() || a)
    print_bool("or  fn||val  (T): ", t() || False)
    print_bool("or  fn||fn   (T): ", f() || t())
    print_bool("or  keyword  (T): ", b or a)
    print_bool("or  True||fn (T): ", True || f())

    // NOT
    print_bool("not !var     (F): ", !a)
    print_bool("not !var     (T): ", !b)
    print_bool("not !val     (F): ", !True)
    print_bool("not !val     (T): ", !False)
    print_bool("not !fn      (F): ", !t())
    print_bool("not !fn      (T): ", !f())
    print_bool("not !!var    (T): ", !!a)
    print_bool("not !!var    (F): ", !!b)
    print_bool("not !!val    (T): ", !!True)
    print_bool("not !!fn     (T): ", !!t())
    print_bool("not !!fn     (F): ", !!f())

    // COMBINED
    print_bool("comb !a||b   (F): ", !a || b)
    print_bool("comb a&&!b   (T): ", a && !b)
    print_bool("comb !a&&!b  (F): ", !a && !b)
    print_bool("comb !f()&&t (T): ", !f() && t())
    print_bool("comb a||b&&b (F): ", a || b && b)

    // WITH IF
    if a && !b:
        printf("if a&&!b: True\n")
    if !a || b:
        printf("if !a||b: should not print\n")
    else:
        printf("if !a||b: False (correct)\n")
