use "@/io"

fn foo() int:
    return 10

fn bar() int:
    return 20

fn print_bool(label chars, val bool) void:
    if val:
        printf("%sTrue\n", label)
    else:
        printf("%sFalse\n", label)

main():
    a int = 10
    b int = 20

    // EQUAL
    print_bool("eq  var==var (F):  ", a == b)
    print_bool("eq  var==val (T):  ", a == 10)
    print_bool("eq  var==fn  (T):  ", a == foo())
    print_bool("eq  val==var (T):  ", 20 == b)
    print_bool("eq  val==val (T):  ", 10 == 10)
    print_bool("eq  fn==fn   (F):  ", foo() == bar())
    print_bool("eq  fn==fn   (T):  ", foo() == foo())

    // NOT EQUAL
    print_bool("neq var!=var (T):  ", a != b)
    print_bool("neq var!=val (F):  ", a != 10)
    print_bool("neq var!=fn  (F):  ", a != foo())
    print_bool("neq val!=val (F):  ", 10 != 10)
    print_bool("neq fn!=fn   (T):  ", foo() != bar())

    // LESS
    print_bool("lt  var<var  (T):  ", a < b)
    print_bool("lt  var<val  (F):  ", a < 5)
    print_bool("lt  var<fn   (F):  ", b < foo())
    print_bool("lt  val<val  (T):  ", 3 < 7)
    print_bool("lt  fn<fn    (T):  ", foo() < bar())

    // LESS EQUAL
    print_bool("le  var<=var (T):  ", a <= b)
    print_bool("le  var<=val (T):  ", a <= 10)
    print_bool("le  var<=fn  (T):  ", a <= foo())
    print_bool("le  val<=val (T):  ", 8 <= 8)
    print_bool("le  fn<=fn   (T):  ", foo() <= bar())
    print_bool("le  fn<=fn   (F):  ", bar() <= foo())

    // GREATER
    print_bool("gt  var>var  (F):  ", a > b)
    print_bool("gt  var>val  (T):  ", b > 10)
    print_bool("gt  var>fn   (T):  ", b > foo())
    print_bool("gt  val>val  (T):  ", 12 > 6)
    print_bool("gt  fn>fn    (F):  ", foo() > bar())

    // GREATER EQUAL
    print_bool("ge  var>=var (T):  ", b >= a)
    print_bool("ge  var>=val (T):  ", a >= 10)
    print_bool("ge  var>=fn  (T):  ", b >= bar())
    print_bool("ge  val>=val (T):  ", 15 >= 15)
    print_bool("ge  fn>=fn   (T):  ", bar() >= foo())
    print_bool("ge  fn>=fn   (F):  ", foo() >= bar())

    // IS keyword
    print_bool("is  var is var(F): ", a is b)
    print_bool("is  fn  is fn (F): ", foo() is bar())
    print_bool("is  fn  is fn (T): ", foo() is foo())

    // CHAINED comparisons via if
    if a < b:
        if a == foo():
            printf("chain: a<b and a==foo: True\n")
