// dungeon/floor17.ura
use "@/header"

fn run() void:
    fd i32 = socket(2, 1, 0)
    if fd < 0:
        output("socket failed\n")
        return

    port i32  = 8080
    addr char[] = heap[char](16)
    addr[0] = 16 as char
    addr[1] = 2  as char
    hi i32 = port >> 8
    lo i32 = port & 255
    addr[2] = hi as char
    addr[3] = lo as char

    bind(fd, addr, 16)
    listen(fd, 5)
    output("listening on :8080\n")

    buf    char[] = heap[char](1024)
    client i32   = accept(fd, null, null)
    if client >= 0:
        n i32 = read(client, buf, 1023)
        if n > 0:
            output("got: ", buf, "\n")
            write(client, "pong\n", 5)
        close(client)
    free(buf)
    free(addr)

main():
    run()
