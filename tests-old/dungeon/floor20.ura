// dungeon/floor20 — operator output and default struct printing
use "@/header"

struct Stats:
    hp  i32
    atk i32

struct Hero:
    name  char[]
    stats Stats
    level i32

    pub fn new(name char[]) Hero:
        h Hero
        h.name      = name
        h.stats.hp  = 100
        h.stats.atk = 20
        h.level     = 1
        return h

    operator output() String:
        s String = String::from(self.name)
        s.join(" lv")
        n String = String::from_int(self.level)
        s.join(n.value)
        s.join(" HP:")
        hp String = String::from_int(self.stats.hp)
        s.join(hp.value)
        return s

struct Loot:
    name  char[]
    value i32

main():
    hero Hero = Hero::new("Aldric")
    output("Hero: ", hero, "\n")

    loot Loot
    loot.name  = "Iron Sword"
    loot.value = 50
    output("Loot: ", loot, "\n")

    s String = String::from("Fireball")
    output("Spell: ", s, "\n")
