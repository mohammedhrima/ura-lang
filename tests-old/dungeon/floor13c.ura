// dungeon/floor13c.ura
use "@/header"

struct Label:
    value char[]
    len   i32

    pub fn new() Label:
        l Label
        l.value = heap[char](64)
        l.len   = 0
        return l

    operator delete() void:
        free(self.value)

    fn set(s char[]) void:
        strcpy(self.value, s)
        self.len = strlen(s) as i32

    operator = (s char[]) void:
        self.set(s)

    operator = (ref v Label) void:
        self.set(v.value)

    fn print() void:
        output(self.value, "\n")

fn hero_rename(hero Label, suffix char[]) void:
    strcat(hero.value, suffix)
    output("inside: ", hero.value, "\n")

main():
    hero Label = Label::new()
    hero = "Aldric"
    hero_rename(hero, " the Brave")
    output("after:  ", hero.value, "\n")
