// operators/overloading/009.ura
use "@/header"

struct String2:
    value char[]
    count i32
    size i32
    
    pub fn new() String2:
        s String2
        s.size  = 10
        s.value = calloc(10 as i64, 1 as i64)
        return s

    operator delete() void:
        free(self.value)

    fn assign (str char[]) void:
        if str == null:
            self.assign("")
            return
        len i32 = strlen(str)
        if self.size < len:
            while self.size < len:
                self.size *= 2
            self.value = realloc(self.value, self.size)

        bzero(self.value, self.size as i64)
        strcpy(self.value, str)
        self.count = len

    fn join(str char[]) void:
        if str == null: return
        res char[] = strjoin(self.value, str)
        self.assign(res)


    operator = (str char[]) void:
        self.assign(str)

    operator = (ref v String2) void:
        self.assign(v.value)

fn add (ref v String2, ref w String2) String2:
    output("v    -> ", v.value, "\n")
    output("self -> ", w.value, "\n")
    res String2 = String2::new()
    res = w
    return res
    
    

main():
    s0 String2 = String2::new()
    s0 = "12345"
    s1 String2 = String2::new()
    s1 = "6789"
    s2 String2 = String2::new()
    s2 = add(s0, s1)
    output("value: ", s2.value, "\n")
