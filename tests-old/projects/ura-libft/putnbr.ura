// libft/putnbr.ura
proto fn calloc(len i32, size i32) pointer
proto fn write(fd i32, ptr pointer, len i32) i32
proto fn free(ptr pointer) i32

fn putchar(c char) i32:
    str char[] = calloc(2, 1)
    str[0] = c
    write(1, str, 1)
    free(str)
    return 0

fn putnbr(n i32) void:
    if n < 0:
        putchar('-')
        n = -n
    
    if n == 0:
        putchar('0')
        return
    
    digits char[] = "0123456789"
    
    // Count digits
    temp i32 = n
    digit_count i32 = 0
    while temp > 0:
        digit_count += 1
        temp = temp / 10
    
    // Allocate buffer for digits
    buffer char[] = calloc(digit_count + 1, 1)
    
    // Build number string from right to left in buffer
    i i32 = digit_count - 1
    while i >= 0:
        digit i32 = n % 10
        buffer[i] = digits[digit]
        n = n / 10
        i -= 1
    
    i = 0
    while i < digit_count:
        putchar(buffer[i])
        i += 1
    
    free(buffer)
    return

main():
    putnbr(123)
    putchar('\n')
    putnbr(-456)
    putchar('\n')
    putnbr(0)
    putchar('\n')
