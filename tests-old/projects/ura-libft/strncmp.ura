// libft/strncmp.ura

use "@/io"

fn strncmp(left char[], right char[], n i32) i32:
    i i32 = 0
    if n == 0: return 0
    while i < n and left[i] == right[i] and left[i] != '\0':
        i += 1
    if i == n: return 0
    return left[i] as i32 - right[i] as i32

main():
    len i32 = strncmp("abd", "abc", 4)
    output(len, "\n")
