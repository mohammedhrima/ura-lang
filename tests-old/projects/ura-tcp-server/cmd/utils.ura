use "@/header"

fn log(msg char[]) void:
    write(1, msg, strlen(msg))

fn get_time() char[]:
    buf char[] = heap[char](16)
    t i64 = time(0 as pointer)
    tm pointer = localtime(t)
    strftime(buf, 16, "%H:%M:%S", tm)
    return buf

fn log_ts(color char[], tag char[], msg char[]) void:
    tbuf char[] = get_time()
    log("\033[0;90m[")
    log(tbuf)
    log("]\033[0m ")
    log(color)
    log(tag)
    log("\033[0m ")
    log(msg)
    log("\n")
    free(tbuf)

fn log_ts_right(color char[], tag char[], msg char[]) void:
    tbuf char[] = get_time()
    log("                    \033[0;90m[")
    log(tbuf)
    log("]\033[0m ")
    log(color)
    log(tag)
    log("\033[0m ")
    log(msg)
    log("\n")
    free(tbuf)

struct SockAddr:
    data char[]

    fn init() void:
        self.data = heap[char](16)
        self.data[0] = 16 as char
        self.data[1] = 2 as char

    fn set_port(port i32) void:
        self.data[2] = (port >> 8) as char
        self.data[3] = (port & 255) as char

    fn set_ip(a i32, b i32, c i32, d i32) void:
        self.data[4] = a as char
        self.data[5] = b as char
        self.data[6] = c as char
        self.data[7] = d as char

    operator delete() void:
        free(self.data)
