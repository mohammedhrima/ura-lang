// refs/011 — a ref reads correctly through the remaining math / comparison / bitwise / cast / logical ops

main():
    a int = 20
    ref r int = ref a
    output(r / 6, "\n")
    output(r % 6, "\n")
    output(r != 20, "\n")
    output(r < 25, "\n")
    output(r <= 20, "\n")
    output(r >= 21, "\n")
    output(r | 3, "\n")
    output(r ^ 4, "\n")
    output(r >> 2, "\n")
    output(r as long, "\n")
    flag bool = True
    ref b bool = ref flag
    output(b and False, "\n")
    output(b or False, "\n")
    output(not b, "\n")
    return 0