// structs/output/003 — operator output returning String (chaining)
use "@/header"

struct Score:
    points i32
    combo  i32

    pub fn new(p i32, c i32) Score:
        s Score
        s.points = p
        s.combo  = c
        return s

    operator output() String:
        s String = String::from_int(self.points)
        s.join("x")
        c String = String::from_int(self.combo)
        s.join(c.value)
        return s

main():
    s Score = Score::new(1500, 3)
    output("Score: ", s, "\n")
    output(s, " — nice!\n")
