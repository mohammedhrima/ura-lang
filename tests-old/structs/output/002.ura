// structs/output/002 — operator output returning char[]
use "@/header"

struct Name:
    first char[]
    last  char[]

    operator output() char[]:
        return self.first

main():
    n Name
    n.first = "Aldric"
    n.last  = "Smith"
    output("name: ", n, "\n")
    output(n, " the Brave\n")
