// string/002 — assign, push, pop, clear, join
use "@/header"

main():
    s String = String::new()
    s = "abc"
    output(s.value, " ", s.len(), "\n")

    s = "hello world this is a longer string"
    output(s.value, "\n")

    s = ""
    output(s.len(), " ", s.empty(), "\n")

    s2 String = String::new()
    s2.push('X')
    s2.push('Y')
    s2.push('Z')
    output(s2.value, " ", s2.len(), "\n")

    c char = s2.pop()
    output(c, " ", s2.value, " ", s2.len(), "\n")

    s2.pop()
    s2.pop()
    c2 char = s2.pop()
    output(c2 as i32, " ", s2.len(), "\n")

    s3 String = String::from("hello")
    s3.join(" world")
    output(s3.value, "\n")

    s3.clear()
    output(s3.len(), " ", s3.empty(), "\n")
